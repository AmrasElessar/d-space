{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "D-Space",
  "version": "0.1.0",
  "identifier": "app.dspace",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "D-Space",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "D-Space",
    "category": "Utility",
    "shortDescription": "Akıllı disk analiz ve geri kazanım",
    "longDescription": "D-Space, Windows üzerinde disk alanını saniyeler içinde haritalayan, ne silinebileceğini bilen ve geri alma garantisi sunan akıllı disk analiz platformudur.",
    "copyright": "Copyright (C) 2026 D-Space contributors. Licensed under GPL-3.0-or-later.",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
